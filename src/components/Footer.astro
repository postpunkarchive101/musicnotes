---
const today = new Date();
---

<footer>
  <p>MUSIC NOTES // a post-punk archive</p>
  <p class="copy">(copyleft) {today.getFullYear()} — all misinformation is free to spread</p>
</footer>
<style>
  footer {
    padding: 2em 1em 3em;
    background: #000;
    color: #555;
    text-align: center;
    border-top: 2px dashed #222;
    font-size: 0.8em;
  }
  footer p {
    margin: 0.3em 0;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .copy {
    font-size: 0.75em;
    color: #333;
  }
</style>
