---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE, SITE_SUBTITLE } from '../consts';
---

<header>
  <div class="masthead">
    <h1><a href="/">{SITE_TITLE}</a></h1>
    <p class="subtitle">{SITE_SUBTITLE}</p>
  </div>
  <nav>
    <HeaderLink href="/">[ HOME ]</HeaderLink>
    <HeaderLink href="/blog">[ BLOG ]</HeaderLink>
    <HeaderLink href="/about">[ ABOUT ]</HeaderLink>
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 1.5em 1em 0.5em;
    background: #000;
    border-bottom: 2px dashed #333;
  }
  .masthead {
    text-align: center;
    margin-bottom: 0.5em;
  }
  .masthead h1 {
    margin: 0;
    font-size: 2.8em;
    letter-spacing: 6px;
  }
  .masthead h1 a,
  .masthead h1 a.active {
    text-decoration: none;
    color: #fff;
  }
  .masthead h1 a:hover {
    color: var(--accent);
  }
  .subtitle {
    margin: 0.25em 0 0;
    font-size: 0.8em;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 4px;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    padding: 0.5em 0;
  }
  nav a {
    padding: 0.3em 0.8em;
    color: #888;
    border: 1px solid #333;
    text-decoration: none;
    font-size: 0.85em;
    letter-spacing: 2px;
    transition: all 0.15s;
  }
  nav a:hover {
    color: #fff;
    border-color: var(--accent);
    background: #111;
  }
  nav a.active {
    color: var(--accent);
    border-color: var(--accent);
    background: #111;
  }
  @media (max-width: 720px) {
    .masthead h1 {
      font-size: 1.8em;
      letter-spacing: 3px;
    }
    nav {
      gap: 0.3em;
    }
    nav a {
      font-size: 0.75em;
      padding: 0.25em 0.5em;
    }
  }
</style>
