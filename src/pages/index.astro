---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="manifesto">
        <p class="lead">
          This is a blog about <strong>post-punk</strong>, <strong>underground</strong>, and the
          <strong>half-forgotten</strong> corners of 80s music.
        </p>
        <p>
          Everything written here is <em>fiction</em>. Every rumour, every demo tape, every
          "I was there" anecdote — fabricated. The bands are real. The stories are not.
        </p>
      </section>

      <hr class="dashed" />

      <section class="latest">
        <h2>>_ LATEST POSTS</h2>
        <p class="muted">
          Check the <a href="/blog">blog</a> for the latest fabrications.
        </p>
      </section>

      <hr class="dashed" />

      <section class="featured">
        <h2>>_ WHY?</h2>
        <p>
          An experiment in <strong>misinformation</strong>. If we write it well enough,
          will the discography sites pick it up? Will the wiki editors believe us?
        </p>
        <p>
          Let's find out.
        </p>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .manifesto .lead {
    font-size: 1.2em;
    line-height: 1.5;
    color: #ddd;
  }
  .dashed {
    margin: 2em 0;
  }
  .latest h2,
  .featured h2 {
    font-size: 1.1em;
    color: var(--accent);
  }
  .muted {
    color: #666;
    font-size: 0.9em;
  }
</style>
